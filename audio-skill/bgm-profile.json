{
  "version": "1.0.0",
  "source": "index.tsx",
  "audioType": "bgm",
  "summary": {
    "trackCount": 3,
    "defaultTrack": "main",
    "activeTrackStateRef": "activeBgmRef",
    "audioInstanceRef": "bgmRef"
  },
  "playbackConfig": {
    "loop": true,
    "volume": 0.35,
    "retryOnUserGesture": true,
    "gestureEvents": ["pointerdown", "keydown"],
    "switchMode": "切换场景时暂停旧音频并创建新 Audio 实例",
    "resumeMode": "同场景且已存在实例时，若处于暂停状态则恢复播放"
  },
  "tracks": [
    {
      "bgmId": "BGM_MAIN",
      "sceneKey": "main",
      "name": "主流程背景音乐",
      "url": "https://gcdncs.101.com/v0.1/static/aic_service_scontent/game/main_bgm.mp3?serviceName=aic_service_scontent&attachment=true",
      "usage": {
        "isDefault": true,
        "stages": ["global", "intro", "select", "sort", "complete", "action-idle"],
        "description": "默认背景音乐；未暂停且未进入行动步骤计时中时播放。"
      }
    },
    {
      "bgmId": "BGM_PROGRESS",
      "sceneKey": "progress",
      "name": "行动进行中背景音乐",
      "url": "https://gcdncs.101.com/v0.1/static/aic_service_scontent/game/progress_bgm.mp3?serviceName=aic_service_scontent&attachment=true",
      "usage": {
        "isDefault": false,
        "stages": ["action-active"],
        "description": "游戏已开始、当前处于 action 步骤且计时器已启动时播放。"
      }
    },
    {
      "bgmId": "BGM_REST",
      "sceneKey": "rest",
      "name": "暂停休息背景音乐",
      "url": "https://gcdncs.101.com/v0.1/static/aic_service_scontent/game/rest_bgm.mp3?serviceName=aic_service_scontent&attachment=true",
      "usage": {
        "isDefault": false,
        "stages": ["pause"],
        "description": "任意时刻只要 `isPaused` 为 true，即优先切换为休息 BGM。"
      }
    }
  ],
  "switchRules": [
    {
      "priority": 1,
      "condition": "isPaused === true",
      "targetScene": "rest",
      "reason": "暂停状态优先级最高。"
    },
    {
      "priority": 2,
      "condition": "hasStarted === true && currentStep === 'action' && isTimerActive === true",
      "targetScene": "progress",
      "reason": "进入正式行动并开始计时后切换为进度 BGM。"
    },
    {
      "priority": 3,
      "condition": "default",
      "targetScene": "main",
      "reason": "其余状态统一回落到主流程 BGM。"
    }
  ],
  "lifecycle": {
    "mount": [
      "绑定用户手势恢复播放监听。"
    ],
    "sceneChange": [
      "根据 `hasStarted`、`currentStep`、`isTimerActive`、`isPaused` 计算目标场景。",
      "调用 `playBgm(scene)` 执行切换。"
    ],
    "unmount": [
      "暂停当前 BGM。",
      "清空 `bgmRef`。",
      "清空 `activeBgmRef`。"
    ]
  },
  "autoplayFallback": {
    "strategy": "浏览器拦截自动播放时保留当前场景，等待用户下一次交互后重试。",
    "successBehavior": "恢复成功后移除 `pointerdown` 与 `keydown` 监听。",
    "stateFlag": "bgmUnlockBoundRef"
  },
  "notes": [
    "BGM 仅按场景状态切换，不区分具体关卡 1/2/3。",
    "暂停状态会覆盖进行中状态，因此休息 BGM 高于 progress BGM。",
    "行动步骤但尚未开始计时时，仍使用主流程背景音乐。"
  ]
}