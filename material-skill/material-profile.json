{
  "version": "1.0.0",
  "source": "index.tsx",
  "scope": {
    "includes": ["scenes", "props"],
    "excludes": ["roles", "roleTTS", "roleStatusCode"]
  },
  "scenes": [
    {
      "id": "step-intro",
      "name": "步骤1-引入场景",
      "stage": "intro",
      "description": "引导点击进入任务流程（本提炼不包含角色实体）"
    },
    {
      "id": "step-select",
      "name": "步骤2-目标选择场景",
      "stage": "select",
      "description": "选择目标数量并触发倒计时"
    },
    {
      "id": "step-sort",
      "name": "步骤3-想象排序场景",
      "stage": "sort",
      "description": "从5个候选中拖拽3个正确步骤到第一步/第二步/第三步槽位"
    },
    {
      "id": "step-action-start",
      "name": "步骤4-行动前场景",
      "stage": "action",
      "description": "显示休息一下/开始行动按钮"
    },
    {
      "id": "pause-screen",
      "name": "暂停场景",
      "stage": "action",
      "description": "暂停覆盖层与继续按钮"
    },
    {
      "id": "timeout-modal",
      "name": "超时弹窗场景",
      "stage": "global",
      "description": "超时提示与重试按钮"
    },
    {
      "id": "reward-modal",
      "name": "过关奖励场景",
      "stage": "complete",
      "description": "星级展示与通关反馈（不含角色信息）"
    },
    {
      "id": "level-1-coloring",
      "name": "第一关-涂色场景",
      "stage": "action",
      "level": 1,
      "description": "调色板 + SVG图案涂色"
    },
    {
      "id": "level-2-puzzle",
      "name": "第二关-七巧板场景",
      "stage": "action",
      "level": 2,
      "description": "轮廓区 + 拼块区，支持旋转与拖放"
    },
    {
      "id": "level-3-basketball",
      "name": "第三关-投篮场景",
      "stage": "action",
      "level": 3,
      "description": "轮次信息 + 可移动篮筐 + 可点击篮球"
    }
  ],
  "props": {
    "global": [
      {
        "id": "timer",
        "type": "ui",
        "label": "倒计时",
        "format": "mm:ss",
        "trigger": "isTimerActive"
      },
      {
        "id": "level-duration-limit",
        "type": "rule",
        "label": "单次关卡时长",
        "value": "2min"
      },
      {
        "id": "goal-options",
        "type": "button-group",
        "options": ["一个/一轮", "两个/两轮"],
        "stage": "select"
      },
      {
        "id": "speaker-button",
        "type": "button",
        "label": "大声说出目标",
        "icon": "📢",
        "stage": "select"
      },
      {
        "id": "countdown",
        "type": "counter",
        "valueRange": [3, 0],
        "stage": "select"
      },
      {
        "id": "action-buttons",
        "type": "button-group",
        "options": ["☕ 休息一下", "🚀 开始行动"],
        "stage": "action"
      },
      {
        "id": "retry-button",
        "type": "button",
        "label": "🔄 重试",
        "stage": "timeout-modal"
      }
    ],
    "byLevel": {
      "1": {
        "name": "第一关-涂色",
        "step3SortImages": {
          "candidateCount": 4,
          "correctCount": 3,
          "decoyCount": 1,
          "correctImages": [
            "房屋图案-未上色",
            "房屋图案-部分上色",
            "房屋图案-完全上色"
          ],
          "decoyImages": [
            "与涂色流程无关的干扰图"
          ],
          "slotLabels": ["第一步", "第二步", "第三步"]
        },
        "step4MainTaskProps": {
          "mainPatterns": ["房屋图案", "花朵图案"],
          "toolProps": ["纯色颜色块(色板)"],
          "interaction": [
            "先点击颜色块选择颜色",
            "再点击图案区域进行填色"
          ]
        }
      },
      "2": {
        "name": "第二关-七巧板",
        "step3SortImages": {
          "candidateCount": 5,
          "correctCount": 3,
          "decoyCount": 2,
          "correctImages": [
            "小鱼图案-已拼1块",
            "小鱼图案-已拼4块",
            "目标图案-完整拼好"
          ],
          "decoyImages": [
            "与七巧板步骤无关的干扰图1",
            "与七巧板步骤无关的干扰图2"
          ],
          "slotLabels": ["第一步", "第二步", "第三步"]
        },
        "step4MainTaskProps": {
          "mainPatterns": ["小鱼轮廓", "轮船轮廓"],
          "toolProps": ["七巧板拼图块(单块可操作)"],
          "interaction": [
            "点击拼图块进行平面旋转",
            "拖拽拼图块到轮廓对应位置",
            "放置正确时高亮反馈",
            "放置错误时快速晃动反馈"
          ]
        }
      },
      "3": {
        "name": "第三关-投篮",
        "step3SortImages": {
          "candidateCount": 5,
          "correctCount": 3,
          "decoyCount": 2,
          "correctImages": [
            "手持篮球准备投篮",
            "篮球在空中飞行",
            "篮球进入篮筐"
          ],
          "decoyImages": [
            "与投篮步骤无关的干扰图1",
            "与投篮步骤无关的干扰图2"
          ],
          "slotLabels": ["第一步", "第二步", "第三步"]
        },
        "step4MainTaskProps": {
          "roundConfig": {
            "roundCount": 2,
            "secondsPerRound": 30
          },
          "toolProps": ["篮球", "移动篮筐"],
          "interaction": [
            "点击篮球触发投球",
            "通过篮球与篮筐重叠判定投中"
          ]
        }
      }
    },
    "clearRule": {
      "description": "按步骤完成即可过关"
    }
  },
  "notes": [
    "当前项目场景与道具主要为代码内嵌 SVG/Emoji/CSS 形态，未使用独立图片素材 URL。",
    "本文件按“素材=场景+道具”提炼，不含角色、角色语音和角色状态码。",
    "关卡道具条目已按截图《数值规则与科学依据》整理。"
  ]
}